rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Safety Net: Deny access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helper: Enforce active session
    function isSignedIn() {
      return request.auth != null;
    }

    // Path Hardening Helper: Confirm ID is valid string format
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Secure Contacts collection
    match /contacts/{contactId} {
      allow read, write: if isSignedIn() && isValidId(contactId);
    }

    // Secure Funnels collection
    match /funnels/{funnelId} {
      allow read, write: if isSignedIn() && isValidId(funnelId);
    }
  }
}
